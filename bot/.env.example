# Token do bot (Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=

# Application ID (Developer Portal -> General Information -> Application ID)
DISCORD_CLIENT_ID=

# (Opcional) ID do servidor de testes — se preenchido, comandos sobem instantâneo só nesse server.
# Em produção (vazio), comandos viram globais (demoram até 1h pra propagar).
DEV_GUILD_ID=

# URL da edge function bot-api do Lovable Cloud
# Formato: https://<projeto>.supabase.co/functions/v1/bot-api
BOT_API_URL=https://srwdikhfrfdmhlfdklzj.supabase.co/functions/v1/bot-api

# A MESMA string que você cadastrou no segredo BOT_API_KEY do Lovable Cloud
BOT_API_KEY=
